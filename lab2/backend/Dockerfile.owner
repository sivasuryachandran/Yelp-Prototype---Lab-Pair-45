FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app ./app
WORKDIR /app/app
EXPOSE 8002

CMD ["uvicorn", "owner_service_main:app", "--host", "0.0.0.0", "--port", "8002"]